---
import ContactForm from '../components/ContactForm.astro';
import '../styles/global.css';

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Toni Wells — remote freelance full stack software engineer & consultant. Available for short-term projects." />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content="Toni Wells — isometimescode.com" />
    <meta property="og:description" content="Remote freelance full stack software engineer & consultant. Available for short-term projects." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.isometimescode.com" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>Toni Wells</title>
  </head>

  <body>
    <div class="site-wrapper">

      <header class="site-header">
        <span class="eyebrow">isometimescode.com</span>
        <h1>Toni <span class="muted">Wells</span></h1>
      </header>

      <div class="divider"></div>

      <main>
        <p class="availability">Available for remote, short-term projects</p>

        <p class="bio">
          Interested in opportunities in consulting, software engineering, infrastructure,
          full-stack web development, technical writing, mentoring, technical
          hiring, and more.
        </p>

        <div class="form-card">
          <ContactForm />
        </div>
      </main>

      <footer class="site-footer">
        <p>&copy; Toni Wells {year}</p>
        <a
          href="https://www.linkedin.com/in/tmwells/"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-linkedin"
          aria-label="LinkedIn profile"
        >
          <!-- LinkedIn icon -->
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </footer>

    </div>
  </body>
</html>
